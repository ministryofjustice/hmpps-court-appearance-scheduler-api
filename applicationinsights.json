{
  "role": {
    "name": "hmpps-court-appearance-scheduler-api"
  },
  "customDimensions": {
    "service.version": "${BUILD_NUMBER}"
  },
  "instrumentation": {
    "logging": {
      "level": "ERROR"
    },
    "springScheduling": {
      "enabled": false
    }
  },
  "selfDiagnostics": {
    "destination": "console"
  },
  "sampling": {
    "percentage": 100,
    "overrides": [
      {
        "telemetryType": "request",
        "attributes": [
          {
            "key": "http.url",
            "value": "https?://[^/]+/health/?.*",
            "matchType": "regexp"
          }
        ],
        "percentage": 0
      },
      {
        "telemetryType": "request",
        "attributes": [
          {
            "key": "http.url",
            "value": "https?://.+/info/?.*",
            "matchType": "regexp"
          }
        ],
        "percentage": 0
      },
      {
        "telemetryType": "request",
        "attributes": [
          {
            "key": "http.url",
            "value": "https?://[^/]+/queue-admin/?.*",
            "matchType": "regexp"
          }
        ],
        "percentage": 0
      },
      {
        "telemetryType": "dependency",
        "attributes": [
          {
            "key": "db.statement"
          }
        ],
        "percentage": 0
      },
      {
        "telemetryType": "exception",
        "attributes": [
          {
            "key": "exception.type",
            "value": "java.util.concurrent.CompletionException",
            "matchType": "strict"
          }
        ],
        "percentage": 0
      }
    ]
  }
}
